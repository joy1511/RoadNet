# ========================================
# ASTROROUTE - ENVIRONMENT VARIABLES
# ========================================
# Copy this file to backend/.env and fill in your actual values

# ========================================
# HUGGING FACE CONFIGURATION (REQUIRED)
# ========================================
# Your HuggingFace API token (get from: https://huggingface.co/settings/tokens)
HUGGINGFACE_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Road Segmentation Model Repository
# Format: username/model-name
HF_SEGMENTATION_MODEL=your-username/road-segmentation-model

# ========================================
# API CONFIGURATION
# ========================================
FLASK_ENV=development
FLASK_DEBUG=True
API_PORT=5000
API_HOST=0.0.0.0

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ========================================
# MODEL CONFIGURATION
# ========================================
# Device selection: cuda, cpu, or auto
DEVICE=auto

# Model inference settings
SEGMENTATION_THRESHOLD=0.5
MAX_IMAGE_SIZE=1024

# ========================================
# GRAPH PROCESSING CONFIGURATION
# ========================================
MAX_GAP_DISTANCE=50
ANGULAR_THRESHOLD=45

# Centrality computation
CENTRALITY_ALGORITHM=betweenness
TOP_N_CRITICAL_NODES=20
ABLATION_ITERATIONS=10

# ========================================
# CACHE & STORAGE
# ========================================
DATA_DIR=./data
CACHE_DIR=./cache
RESULTS_DIR=./results
TEMP_DIR=./temp
ENABLE_CACHE=True
CACHE_TTL=3600

# ========================================
# LOGGING
# ========================================
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# ========================================
# SECURITY
# ========================================
MAX_UPLOAD_SIZE=50
ALLOWED_EXTENSIONS=png,jpg,jpeg,tif,tiff
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ========================================
# FRONTEND CONFIGURATION
# ========================================
VITE_API_BASE_URL=http://localhost:5000
